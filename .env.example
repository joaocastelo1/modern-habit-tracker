# GEMINI_API_KEY: Necessária para chamadas de IA (se houver).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: URL da aplicação.
APP_URL="MY_APP_URL"

# DATABASE_URL: String de conexão com o PostgreSQL (ex: postgres://user:password@host:port/db)
DATABASE_URL="postgres://postgres:postgres@localhost:5432/habit_tracker"
